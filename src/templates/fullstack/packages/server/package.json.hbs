{
  "name": "@{{packageName}}/server",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""{{#if usePrisma}},
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"{{/if}}
  },
  "dependencies": {
    "@{{packageName}}/shared": "0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "zod": "^3.23.8"{{#if usePrisma}},
    "@prisma/client": "^5.22.0"{{/if}}
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "nodemon": "^3.1.7"{{#if usePrisma}},
    "prisma": "^5.22.0"{{/if}},
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
