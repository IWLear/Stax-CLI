{
  "name": "{{packageName}}",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"{{#if usePrisma}},
    "prisma:generate": "npm run prisma:generate -w @{{packageName}}/server",
    "prisma:migrate": "npm run prisma:migrate -w @{{packageName}}/server"{{/if}}
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.1",
    "typescript": "^5.6.3"
  }
}
